# ── Database (Postgres) ──────────────────────────────────────────────
# For LOCAL (non-docker) runs. The docker stack exposes Postgres on host port 5433.
DATABASE_URL=postgresql+psycopg://gitly:gitly@localhost:5433/gitly

# ── Queue (Redis + Celery) ───────────────────────────────────────────
# The docker stack exposes Redis on host port 6380.
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1

# ── API ──────────────────────────────────────────────────────────────
GITLY_CORS_ORIGINS=http://localhost:3000
# Any localhost/127.0.0.1 port is allowed in dev via this regex (default below).
# Override to lock down in production.
# GITLY_CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?

# ── Secret firewall ──────────────────────────────────────────────────
# Block commits/prompts that contain secrets. Layered scan (high-recall regex + entropy).
GITLY_SECRET_SCAN=true
GITLY_SECRET_FAIL_CLOSED=true        # block on any finding (recommended for vibe coders)

# ── Provenance (trace) ───────────────────────────────────────────────
GITLY_PROVENANCE_LEDGER=.gitly/provenance   # local append-only authorship ledger
GITLY_PROVENANCE_SYNC=false                 # opt-in: push bound records to backend/dashboard

# ── LLM (OPTIONAL · opt-in · your own key) ───────────────────────────
# Used for intent labels / commit messages. Diffs & prompts are SECRET-REDACTED before any call.
GITLY_ANTHROPIC_API_KEY=

# ── GitHub App (OPTIONAL · hosted shrink) ────────────────────────────
GITLY_GITHUB_APP_ID=
GITLY_GITHUB_WEBHOOK_SECRET=
GITLY_GITHUB_PRIVATE_KEY_PATH=

# ── Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
